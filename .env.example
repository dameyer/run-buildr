INVITE_CODE=your_invite_code_here

# Wahoo Cloud API app credentials — register at https://developers.wahooligan.com/applications
WAHOO_CLIENT_ID=your_client_id_here
WAHOO_CLIENT_SECRET=your_client_secret_here
# Required: signs session cookies; min 32 chars, validated at startup.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change_this_to_a_random_string
REDIRECT_URI=http://127.0.0.1:9000/auth/wahoo/callback

# Required: encrypts Wahoo/Garmin tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_this_to_a_generated_fernet_key
